# Copy to `.env` in this folder (Vite reads `VITE_*` at build/dev time).

# Base URL of the VidU API (no trailing slash). Used by `src/api/client.ts` once services are wired;
# pages and stores do not call the network until you add `src/api/services/` and `src/api/queries/`.
VITE_API_URL=http://localhost:3001

# Set to `true` in deployed builds to print `[VidU Auth]` logs in the browser console.
# VITE_AUTH_DEBUG=true

# Minimum full-screen logo loader after Google sign-in (ms). Set to 0 to disable.
# VITE_POST_LOGIN_MIN_LOAD_MS=3500
